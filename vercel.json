{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/layanan", "destination": "/pages/layanan.html" },
    { "source": "/about",   "destination": "/pages/about.html" },
    { "source": "/contact", "destination": "/pages/contact.html" },
    { "source": "/fitur",   "destination": "/pages/fitur.html" },
    { "source": "/artikel", "destination": "/pages/artikel.html" },
    { "source": "/promo",   "destination": "/pages/promo.html" },
    { "source": "/",        "destination": "/index.html" }
  ]
}